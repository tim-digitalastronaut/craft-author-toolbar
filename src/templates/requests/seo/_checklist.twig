{# ======================= #}
{# PROPERTIES              #}
{# ======================= #}
{% set checklist = checklist|default([]) %}

{# ======================= #}
{# TEMPLATE                #}
{# ======================= #}
<div class="cat-toolbar-seo-menu-checklist-top">
    <h2 class="cat-typo-body-md cat-semi-bold">{{ "Checklist"|t('author-toolbar') }}</h2>

    <p class="cat-typo-body-sm">
        {{ "This is a basic checklist that all pages should try to check off for a well maintained SEO performance"|t('author-toolbar') }}
    </p>
</div>

{% if checklist|length %}
    <ul class="cat-toolbar-seo-menu-checklist-results">
        {% for check in checklist %}
            <li class="cat-toolbar-seo-menu-checklist-results-item">
                <div class="cat-toolbar-seo-menu-checklist-results-item-icon {{ check.status }}">
                    {{ svg("@digitalastronaut/craftauthortoolbar/web/icons/" ~ check.status ~ ".svg") }}
                </div>

                <p class="cat-typo-body-sm">{{ check.message }}</p>
            </li>
        {% endfor %}
    </ul>
{% endif %}
