{# ======================= #}
{# PROPERTIES              #}
{# ======================= #}
{% set headings = headings|default([]) %}
{% set headingsCount = headings|filter(heading => not heading.missing)|length|default(0) %}

{# ======================= #}
{# TEMPLATE                #}
{# ======================= #}
<div class="cat-toolbar-seo-menu-headings-top">
    <h2 class="cat-typo-body-md cat-semi-bold">
        {{ "Page headings"|t('author-toolbar') }}
        <span>({{ headingsCount }})</span>
    </h2>

    <p class="cat-typo-body-sm">
        {{ "This is the structure of headings on this page. Make sure the headings follow the correct hierarchy"|t('author-toolbar') }}
    </p>
</div>

<ul class="cat-toolbar-seo-menu-headings-list">
    {% for heading in headings %}
        <li class="cat-toolbar-seo-menu-headings-list-item">
            <button class="cat-toolbar-seo-menu-headings-list-item-link {{ heading.missing ? "missing" : "" }}">
                {% for index in range(0, heading.level) %}
                    {% if not loop.first %}<span></span>{% endif %}
                {% endfor %}

                <p class="cat-typo-body-sm cat-semi-bold">{{ heading.tag }}</p>

                <p class="cat-typo-body-sm">{{ heading.text }}</p>
            </button>
        </li>
    {% endfor %}
</ul>